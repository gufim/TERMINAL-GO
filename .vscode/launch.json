/**
        * @file launch.json
        * @description SunGo Project Manager - Konfiguracja debuggera i uruchamiania.
        * Definiuje profile dla trybu deweloperskiego (Debug) oraz optymalizowanego (Release).
        * * @project TERMINAL
        * @author SunRiver-LotharTeaM (Andrzej Gromczyński)
        * @version 0.2.8
        */

{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/src",
            "output": "${workspaceFolder}/bin/_debug_TERMINAL"
        },
        {
            "name": "Release",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/src",
            "output": "${workspaceFolder}/bin/TERMINAL"
        }
    ]
}